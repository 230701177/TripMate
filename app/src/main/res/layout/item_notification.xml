<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="@dimen/spacing_small"
    app:cardBackgroundColor="@color/colorSurface"
    app:cardCornerRadius="@dimen/corner_radius"
    app:cardElevation="@dimen/card_elevation">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_medium">

        <com.google.android.material.button.MaterialButton
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:backgroundTint="@color/colorSurfaceElevated"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_dialog_info"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/colorPrimary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_medium"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNotifTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notification Title"
                android:textAppearance="@style/TextAppearance.TripMate.Heading.Small" />

            <TextView
                android:id="@+id/tvNotifMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Message"
                android:textColor="@color/colorTextHint"
                android:textAppearance="@style/TextAppearance.TripMate.Body" />

            <TextView
                android:id="@+id/tvNotifTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.TripMate.Caption" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
