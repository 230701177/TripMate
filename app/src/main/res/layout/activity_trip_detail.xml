<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true"
    android:padding="@dimen/spacing_medium">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="96dp">

        <!-- Header Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/headerLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="@dimen/corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_margin="@dimen/spacing_medium">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/spacing_large">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    app:backgroundTint="@color/colorSurfaceElevated"
                    app:cornerRadius="10dp"
                    app:icon="@android:drawable/ic_media_previous"
                    app:iconGravity="textStart"
                    app:iconTint="@color/colorText" />

                <TextView
                    android:id="@+id/tvTripTitleDetail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_medium"
                    android:text="Trip Title"
                    android:textAppearance="@style/TextAppearance.TripMate.Heading"
                    android:textColor="@color/colorText"
                    app:layout_constraintTop_toBottomOf="@id/btnBack"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tvTripDatesDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Dates"
                    android:textColor="@color/colorTextHint"
                    android:textAppearance="@style/TextAppearance.TripMate.Body"
                    app:layout_constraintTop_toBottomOf="@id/tvTripTitleDetail"
                    app:layout_constraintStart_toStartOf="@id/tvTripTitleDetail" />

                <TextView
                    android:id="@+id/tvBudget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:text="Budget: —"
                    android:textColor="@color/colorPrimary"
                    android:textAppearance="@style/TextAppearance.TripMate.Body"
                    app:layout_constraintTop_toBottomOf="@id/tvTripDatesDetail"
                    app:layout_constraintStart_toStartOf="@id/tvTripTitleDetail" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Action Buttons Row -->
        <LinearLayout
            android:id="@+id/buttonRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="@dimen/spacing_medium"
            app:layout_constraintTop_toBottomOf="@id/headerLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChecklist"
                style="@style/Widget.TripMate.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Checklist" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExpense"
                style="@style/Widget.TripMate.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Expense" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEvent"
                style="@style/Widget.TripMate.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Event" />
        </LinearLayout>

        <!-- Itinerary Header -->
        <TextView
            android:id="@+id/tvItineraryHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_medium"
            android:text="Itinerary"
            android:textAppearance="@style/TextAppearance.TripMate.Heading"
            app:layout_constraintTop_toBottomOf="@id/buttonRow"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Itinerary RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvItinerary"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/spacing_small"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/spacing_large"
            app:layout_constraintTop_toBottomOf="@id/tvItineraryHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- FAB to add activity -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddActivity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/spacing_medium"
            app:backgroundTint="@color/colorPrimary"
            app:srcCompat="@android:drawable/ic_input_add"
            app:tint="@color/black"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>