<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom-right shadow -->
    <item android:top="8dp" android:left="8dp" android:bottom="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/shadow_dark" />
            <corners android:radius="@dimen/corner_radius" />
        </shape>
    </item>
    <item android:top="6dp" android:left="6dp" android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#240C1A24" />
            <corners android:radius="@dimen/corner_radius" />
        </shape>
    </item>

    <!-- Top-left highlight -->
    <item android:bottom="8dp" android:right="8dp" android:top="0dp" android:left="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/shadow_light" />
            <corners android:radius="@dimen/corner_radius" />
        </shape>
    </item>

    <!-- Main surface -->
    <item android:bottom="4dp" android:right="4dp" android:top="4dp" android:left="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/surface_top"
                android:endColor="@color/surface_bottom" />
            <corners android:radius="@dimen/corner_radius" />
            <stroke android:width="1dp" android:color="#38FFFFFF" />
        </shape>
    </item>
</layer-list>
