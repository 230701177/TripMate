<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="5dp" android:left="5dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#220C1A24" />
            <corners android:radius="@dimen/corner_radius" />
        </shape>
    </item>

    <item android:top="0dp" android:left="0dp" android:right="5dp" android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="#A6FFFFFF" />
            <corners android:radius="@dimen/corner_radius" />
        </shape>
    </item>

    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/surface_low_top"
                android:endColor="@color/surface_low_bottom" />
            <corners android:radius="@dimen/corner_radius" />
        </shape>
    </item>
</layer-list>
