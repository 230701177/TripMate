<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom-right shadow -->
    <item android:top="8dp" android:left="8dp" android:bottom="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#340F5F50" />
            <corners android:radius="@dimen/corner_radius" />
        </shape>
    </item>
    <item android:top="6dp" android:left="6dp" android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#3F1B806A" />
            <corners android:radius="@dimen/corner_radius" />
        </shape>
    </item>

    <!-- Top-left highlight -->
    <item android:bottom="8dp" android:right="8dp" android:top="0dp" android:left="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#80FFFFFF" />
            <corners android:radius="@dimen/corner_radius" />
        </shape>
    </item>

    <!-- Main surface -->
    <item android:bottom="4dp" android:right="4dp" android:top="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#4BC2A8"
                android:endColor="@color/colorPrimary" />
            <corners android:radius="@dimen/corner_radius" />
        </shape>
    </item>
    
    <!-- Inner top rim -->
    <item android:bottom="6dp" android:right="6dp" android:top="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <stroke android:width="2dp" android:color="#4DFFFFFF" />
            <corners android:radius="@dimen/corner_radius" />
        </shape>
    </item>
</layer-list>
