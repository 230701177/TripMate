<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Typography -->
    <style name="TextAppearance.TripMate.Title" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/colorText</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.TripMate.Heading" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/colorText</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.TripMate.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/colorText</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.TripMate.Body.Strong" parent="TextAppearance.TripMate.Body">
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.TripMate.Heading.Small" parent="TextAppearance.TripMate.Heading">
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.TripMate.Heading.Large" parent="TextAppearance.TripMate.Heading">
        <item name="android:textSize">24sp</item>
    </style>

    <style name="TextAppearance.TripMate.Display" parent="TextAppearance.TripMate.Title">
        <item name="android:textSize">42sp</item>
    </style>

    <style name="TextAppearance.TripMate.Caption" parent="TextAppearance.TripMate.Body">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/colorTextHint</item>
    </style>

    <style name="TextAppearance.TripMate.FormLabel" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/colorTextHint</item>
    </style>

    <!-- Shared surfaces and controls -->
    <style name="Widget.TripMate.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">14dp</item>
        <item name="cardElevation">1dp</item>
        <item name="cardBackgroundColor">@color/colorSurface</item>
    </style>

    <style name="Widget.TripMate.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="Widget.TripMate.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:minHeight">48dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/colorSurfaceElevated</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/colorText</item>
    </style>

    <style name="Widget.TripMate.Input" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundMode">outline</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxBackgroundColor">@color/colorSurfaceElevated</item>
        <item name="boxStrokeColor">@color/colorPrimary</item>
        <item name="hintTextColor">@color/colorTextHint</item>
    </style>

</resources>