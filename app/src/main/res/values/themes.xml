<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TripMate" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Brand colors -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorError">@color/colorAccent</item>
        <item name="colorOnError">@color/black</item>

        <!-- Surfaces -->
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorText</item>
        <item name="colorSurfaceVariant">@color/colorSurfaceElevated</item>
        <item name="colorOutline">@color/colorOutline</item>

        <!-- System UI -->
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Global backgrounds and text -->
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:textColor">@color/colorText</item>
        <item name="android:textColorHint">@color/colorTextHint</item>

        <!-- Shared component styles -->
        <item name="materialButtonStyle">@style/Widget.TripMate.Button.Primary</item>
        <item name="materialCardViewStyle">@style/Widget.TripMate.Card</item>
    </style>
</resources>